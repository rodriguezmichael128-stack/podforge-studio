# PodForge server
PORT=4175
PUBLIC_BASE_URL=http://127.0.0.1:4175

# Admin portal
ADMIN_PATH=/admin
ADMIN_LOGIN_REQUIRED=true
ADMIN_PASSWORD=replace_with_a_private_password
ADMIN_SESSION_HOURS=12

# Stripe test mode
# Get this from Stripe Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=sk_test_replace_me

# Get this from Stripe Dashboard > Developers > Webhooks after creating an endpoint.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Keep false until legal terms, Stripe review, and internal QA are complete.
PODFORGE_ENABLE_LIVE_CHARGES=false
